# 1. GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio handles this automatically via the reserved 'GEMINI_API_KEY' secret.
# For Vercel, add 'VITE_GEMINI_API_KEY' to your Environment Variables setting.
VITE_GEMINI_API_KEY=

# 2. APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
